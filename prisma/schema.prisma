generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── КОРИСТУВАЧІ ─────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  orders    Order[]
  reviews   Review[] // відгуки користувача
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

// ─── ТОВАРИ ──────────────────────────────────

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isActive    Boolean  @default(true)
  stock       Int      @default(0)
  category    String? // категорія товару
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  orderItems OrderItem[]
  reviews    Review[] // відгуки на товар
}

// ─── ЗАМОВЛЕННЯ ──────────────────────────────

model Order {
  id Int @id @default(autoincrement())

  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  items      OrderItem[]
  totalPrice Float
  status     OrderStatus @default(PENDING)
  firstName  String
  lastName   String
  email      String
  phone      String
  address    String
  city       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now()) @updatedAt
}

enum OrderStatus {
  PENDING // Очікує
  PROCESSING // В обробці
  SHIPPED // Відправлено
  DELIVERED // Доставлено
  CANCELLED // Скасовано
}

// Товари всередині замовлення
// Зберігає ціну на момент покупки — навіть якщо ціна товару зміниться
model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  name      String
  quantity  Int // кількість — можна змінювати
  price     Float // ціна на момент покупки
}

// ─── ВІДГУКИ ─────────────────────────────────

model Review {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  rating    Int // оцінка від 1 до 5
  comment   String? // текст відгуку
  createdAt DateTime @default(now())
}

// ─── CMS (НАЛАШТУВАННЯ СТОРІНОК) ─────────────

// Для адмін панелі → Pages Settings
model Page {
  id        Int      @id @default(autoincrement())
  slug      String   @unique // наприклад "home", "about"
  title     String
  content   Json // зберігаємо блоки контенту
  updatedAt DateTime @updatedAt
}
