generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  orders    Order[]
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

model Order {
  id         Int         @id @default(autoincrement())
  user       User        @relation(fields: [userId], references: [id])
  userId     Int
  items      OrderItem[]
  totalPrice Float
  status     OrderStatus @default(PENDING)
  firstName  String
  lastName   String
  email      String
  phone      String
  address    String
  city       String
  createdAt  DateTime    @default(now())
}

enum OrderStatus {
  PENDING // Очікує
  PROCESSING // В обробці
  SHIPPED // Відправлено
  DELIVERED // Доставлено
  CANCELLED // Скасовано
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  order   Order @relation(fields: [orderId], references: [id])
  orderId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  quantity Int
  price    Float // ціна на момент покупки
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  stock       Int      @default(0)

  orderItems OrderItem[]
}
